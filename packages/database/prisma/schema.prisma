// Workforce Scheduling & Billing — Prisma Schema
// Database: Azure Database for PostgreSQL Flexible Server

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  WORKER
}

enum AdminPermission {
  OPERATIONS
  FINANCE
}

enum CaseStatus {
  DRAFT
  ACTIVE
  CLOSED
  READY_FOR_REVIEW
  COMPLETED
  CANCELLED
  // Full lifecycle states (spec: sale/planning → execution → payment/closure)
  LEAD
  QUOTATION_DRAFT
  AWAITING_APPROVAL
  RESERVED
  APPROVED_NO_DATES
  PARTIALLY_SCHEDULED
  READY_FOR_EXECUTION
  IN_PROGRESS
  AWAITING_COMPLETION
  AWAITING_BILLING
  AWAITING_PAYMENT
  PAID
}

enum JobType {
  PACKING
  UNPACKING
  HOME_ORGANIZATION
}

// Owner-visible job lifecycle (spec §4). Every new job starts as RESERVATION
// and is published to workers immediately (no draft state). ARCHIVED replaces
// the old CANCELLED status; permanent deletion is a separate hard-delete.
enum JobStatus {
  RESERVATION
  APPROVED
  COMPLETED
  ARCHIVED
}

enum StaffingMode {
  AUTO_APPROVE
  MANAGER_APPROVAL
}

enum WorkerSkill {
  SHIFT_LEADER
  PACKING_SPECIALIST
  UNPACKING_SPECIALIST
  ORGANIZATION_SPECIALIST
  DRIVER
  GENERAL_WORKER
}

enum JoinRequestStatus {
  PENDING
  AWAITING_WORKER
  APPROVED
  REJECTED
  CANCELLED
}

// A worker's role on a specific job (spec §3.5). TEAM_LEADER counts toward the
// required worker count (§10); BACKUP is an extra worker beyond the requirement
// (§11) and does not fill a required position.
enum AssignmentRole {
  REGULAR
  TEAM_LEADER
  BACKUP
}

enum AttendanceStatus {
  SCHEDULED
  PROPOSED
  CLOCKED_IN
  CLOCKED_OUT
  NO_SHOW
  CORRECTED
  AUTO_CLOCKED_OUT
}

enum AttendanceMethod {
  NORMAL
  ADMIN_CORRECTED
  MANUALLY_ADDED
  AUTO_CLOCK_OUT
}

enum ReplacementStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

// Two-way shift swap between two workers (worker_web_spec §3 Two-way swap).
enum SwapStatus {
  PENDING_WORKER
  PENDING_OWNER
  APPROVED
  REJECTED
  CANCELLED
}

// A worker's sign-off on their published monthly report (worker_web_spec §Reports).
enum ReportApprovalStatus {
  PENDING
  APPROVED
  CHANGES_REQUESTED
}

// Worker feedback on a monthly report: a comment on a job, or a missing-shift report.
enum ReportNoteType {
  COMMENT
  MISSING_SHIFT
}

enum BillingModel {
  HOURLY
  FIXED
  CUSTOM
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  BIT
  CHECK
  OTHER
}

enum AddressLabel {
  OLD_APARTMENT
  NEW_APARTMENT
  STORAGE
  OFFICE
  OTHER
}

enum FormQuestionType {
  YES_NO
  MULTIPLE_CHOICE
  CHECKBOX
  NUMBER
  SHORT_TEXT
  LONG_TEXT
  PHOTO_UPLOAD
  DATE
  SIGNATURE
}

enum FormQuestionVisibility {
  WORKER
  ADMIN
  OWNER
}

enum FormSubmissionStatus {
  NOT_SUBMITTED
  SUBMITTED
  WAIVED
}

enum CompletionStatus {
  COMPLETED
  PARTIALLY_COMPLETED
  NOT_COMPLETED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  CLOCK_IN
  CLOCK_OUT
  AUTO_CLOCK_OUT
  CORRECTION
  MONTH_CLOSE
  MONTH_REOPEN
  PERMISSION_CHANGE
}

enum ExpenseCategory {
  SOFTWARE
  MARKETING
  INSURANCE
  ACCOUNTANT
  OFFICE
  EQUIPMENT
  VEHICLE
  PARKING
  SUPPLIES
  OTHER
}

enum ReportingBasis {
  ACCRUAL
  CASH
}

// ─── User (Clerk-managed identity, mirrored here for relations) ───────────────

model User {
  id          String   @id // Clerk user ID
  email       String   @unique
  firstName   String
  lastName    String
  role        UserRole
  isActive    Boolean  @default(true)
  permissions AdminPermission[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  workerProfile  Worker?
  auditLogs      AuditLog[]
  assignedCases  CustomerCase[]  @relation("CaseManager")

  @@map("users")
}

// ─── Worker ───────────────────────────────────────────────────────────────────

model Worker {
  id                  String   @id @default(cuid())
  userId              String   @unique
  firstName           String
  lastName            String
  phone               String
  email               String   @unique
  hourlyWage          Decimal  @db.Decimal(10, 2)
  dailyPaymentAmount  Decimal  @db.Decimal(10, 2)
  paymentMethod       PaymentMethod
  skills              WorkerSkill[]
  isActive            Boolean  @default(true)
  homeArea            String?
  notes               String?
  internalNotes       String?
  expoPushToken       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  user                User     @relation(fields: [userId], references: [id])
  shifts              Shift[]
  availability        WorkerAvailability[]
  replacementRequests ReplacementRequest[] @relation("ReplacementOriginal")
  suggestedReplacements ReplacementRequest[] @relation("ReplacementSuggested")
  approvedReplacements ReplacementRequest[] @relation("ReplacementApproved")
  reportApprovals     WorkerReportApproval[]
  monthlyReports      WorkerMonthlyReport[]
  reportNotes         WorkerReportNote[]
  replacementVolunteers ReplacementVolunteer[]
  swapsProposed       ShiftSwap[]          @relation("SwapFromWorker")
  swapsReceived       ShiftSwap[]          @relation("SwapToWorker")

  @@map("workers")
}

enum AvailabilityBlockType {
  DATE
  RANGE
  WEEKLY
}

// Dates/weekdays a worker has marked as unavailable (worker_web_spec §3).
model WorkerAvailability {
  id        String                @id @default(cuid())
  workerId  String
  type      AvailabilityBlockType
  startDate DateTime?
  endDate   DateTime?
  weekday   Int?
  reason    String?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  worker    Worker                @relation(fields: [workerId], references: [id])

  @@index([workerId])
  @@map("worker_availability")
}

// ─── Customer ─────────────────────────────────────────────────────────────────

model Customer {
  id                 String   @id @default(cuid())
  firstName          String
  lastName           String
  phone              String
  email              String?
  preferredContact   String?
  notes              String?
  parkingInstructions String?
  accessInstructions String?
  elevatorInfo       String?
  petInfo            String?
  specialRequests    String?
  internalNotes      String?
  isActive           Boolean  @default(true)
  // System customers (e.g. "General Reservation" / שריון כללי) cannot be deleted
  // and are used to reserve workforce before a real customer exists (spec §3.2).
  isSystem           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  addresses          Address[]
  cases              CustomerCase[]
  jobs               Job[]

  @@map("customers")
}

// ─── Address ──────────────────────────────────────────────────────────────────

model Address {
  id               String       @id @default(cuid())
  customerId       String
  fullAddress      String
  apartmentDetails String?
  label            AddressLabel
  accessNotes      String?
  parkingNotes     String?
  elevatorNotes    String?
  // Geocoded coordinates for the 500m attendance geofence (§16.1/§16.4). Nullable
  // until an address is geocoded; when absent, attendance falls back to the
  // owner-review flow and the mobile leaving-area watcher stays inactive.
  latitude         Float?
  longitude        Float?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relations
  customer         Customer     @relation(fields: [customerId], references: [id])
  jobs             Job[]

  @@map("addresses")
}

// ─── Customer Case ────────────────────────────────────────────────────────────

model CustomerCase {
  id                   String     @id @default(cuid())
  customerId           String
  name                 String
  status               CaseStatus @default(ACTIVE)
  startDate            DateTime?
  latestActivityDate   DateTime?
  assignedAdminId      String?
  internalNotes        String?
  finalReportStatus    String?    // 'NOT_GENERATED' | 'DRAFT' | 'SENT'
  customerReportStatus String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  // Relations
  customer             Customer   @relation(fields: [customerId], references: [id])
  assignedAdmin        User?      @relation("CaseManager", fields: [assignedAdminId], references: [id])
  jobs                 Job[]
  reportVersions       CustomerReportVersion[]

  @@map("customer_cases")
}

// ─── Customer report version (spec §18) ───────────────────────────────────────
// Each finalized customer report is an immutable snapshot. Versions form a chain
// per case (corrections add a new version; earlier versions are preserved). The
// PDF is reproducible from `snapshot`, never from mutable live job data.
model CustomerReportVersion {
  id            String       @id @default(cuid())
  caseId        String
  versionNumber Int
  status        String       @default("FINALIZED")
  snapshot      Json
  pdf           Bytes?
  createdById   String?
  supersedesId  String?
  createdAt     DateTime     @default(now())

  case          CustomerCase @relation(fields: [caseId], references: [id])

  @@unique([caseId, versionNumber])
  @@index([caseId])
  @@map("customer_report_versions")
}

// ─── Job ──────────────────────────────────────────────────────────────────────

model Job {
  id                   String       @id @default(cuid())
  caseId               String
  customerId           String
  addressId            String
  jobType              JobType
  date                 DateTime
  plannedStart         DateTime
  plannedEnd           DateTime
  requiredWorkerCount  Int
  staffingMode         StaffingMode @default(AUTO_APPROVE)
  jobNotes             String?
  workerVisibleNotes   String?
  billingModel         BillingModel?
  billingRate          Decimal?     @db.Decimal(10, 2)
  locationRadiusMeters Int          @default(500)
  status               JobStatus    @default(RESERVATION)
  reportedAt           DateTime?
  idempotencyKey       String?      @unique
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  // Relations
  case                 CustomerCase @relation(fields: [caseId], references: [id])
  customer             Customer     @relation(fields: [customerId], references: [id])
  address              Address      @relation(fields: [addressId], references: [id])
  slots                JobSlot[]
  shifts               Shift[]
  expenses             JobExpense[]
  formTemplate         FormTemplate? @relation(fields: [formTemplateId], references: [id])
  formTemplateId       String?

  @@map("jobs")
}

// ─── Job Slot (required role per position) ────────────────────────────────────

model JobSlot {
  id             String      @id @default(cuid())
  jobId          String
  requiredSkill  WorkerSkill?
  label          String?
  filledByShiftId String?

  job            Job         @relation(fields: [jobId], references: [id])

  @@map("job_slots")
}

// ─── Shift ────────────────────────────────────────────────────────────────────

model Shift {
  id                      String             @id @default(cuid())
  workerId                String
  jobId                   String
  slotId                  String?
  scheduledStart          DateTime
  scheduledEnd            DateTime
  actualStart             DateTime?
  actualEnd               DateTime?
  clockInLat              Float?
  clockInLon              Float?
  clockInDistanceMeters   Float?
  clockOutLat             Float?
  clockOutLon             Float?
  clockOutDistanceMeters  Float?
  attendanceStatus        AttendanceStatus   @default(SCHEDULED)
  clockInMethod           AttendanceMethod?
  clockOutMethod          AttendanceMethod?
  joinRequestStatus       JoinRequestStatus  @default(PENDING)
  assignmentRole          AssignmentRole     @default(REGULAR)
  replacementStatus       ReplacementStatus  @default(NONE)
  formStatus              FormSubmissionStatus @default(NOT_SUBMITTED)
  approvedHours           Decimal?           @db.Decimal(10, 2)
  hourlyWageSnapshot      Decimal            @db.Decimal(10, 2)
  dailyPaymentSnapshot    Decimal            @db.Decimal(10, 2)
  isDailyPaymentEligible  Boolean            @default(false)
  workerNameSnapshot      String
  requiresReview          Boolean            @default(false)
  // ── Persisted time-based state for the attendance sweep (spec §16.2/§16.4/§17.3).
  // Timers live in the DB (not app/mobile memory) so restarts/downtime never skip
  // scheduled actions; the sweep re-reads and re-checks these transactionally.
  proposedClockIn         DateTime?          // §16.2 proposed clock-in time (== scheduledStart) once a missing-clock-in proposal is created
  areaExitAt              DateTime?          // §16.4 first confirmed exit from the geofence
  areaExitDeadline        DateTime?          // §16.4 auto-clock-out deadline (areaExitAt + 15m)
  formDeadline            DateTime?          // §17.3 end-of-next-day deadline for the end form (set at clock-out when a form is enabled)
  formLastReminderAt      DateTime?          // §17.3 last end-form reminder sent (drives the every-3h cadence)
  formOverdue             Boolean            @default(false) // §17.3 end form passed its deadline (informational)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  // Relations
  worker                  Worker             @relation(fields: [workerId], references: [id])
  job                     Job                @relation(fields: [jobId], references: [id])
  attendanceCorrections   AttendanceCorrection[]
  locationChecks          LocationCheck[]
  replacementRequests     ReplacementRequest[]
  formSubmission          FormSubmission?
  swapsFrom               ShiftSwap[]        @relation("SwapFromShift")
  swapsTo                 ShiftSwap[]        @relation("SwapToShift")

  @@map("shifts")
}

// ─── Attendance Correction ────────────────────────────────────────────────────

model AttendanceCorrection {
  id             String   @id @default(cuid())
  shiftId        String
  correctedById  String
  clockIn        DateTime?
  clockOut       DateTime?
  reason         String
  internalNote   String?
  createdAt      DateTime @default(now())

  shift          Shift    @relation(fields: [shiftId], references: [id])

  @@map("attendance_corrections")
}

// ─── Location Check ───────────────────────────────────────────────────────────

model LocationCheck {
  id              String   @id @default(cuid())
  shiftId         String
  latitude        Float
  longitude       Float
  distanceMeters  Float
  isWithinRadius  Boolean
  checkedAt       DateTime @default(now())
  workerResponse  String?  // 'END_SHIFT' | 'STILL_WORKING' | 'REPORT_ISSUE' | 'NO_RESPONSE'

  shift           Shift    @relation(fields: [shiftId], references: [id])

  @@map("location_checks")
}

// ─── Replacement Request ──────────────────────────────────────────────────────

model ReplacementRequest {
  id                   String            @id @default(cuid())
  shiftId              String
  requestedByWorkerId  String
  reason               String
  suggestedWorkerId    String?
  approvedWorkerId     String?
  status               ReplacementStatus @default(PENDING)
  adminNote            String?
  resolvedAt           DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  shift                Shift             @relation(fields: [shiftId], references: [id])
  requestedByWorker    Worker            @relation("ReplacementOriginal", fields: [requestedByWorkerId], references: [id])
  suggestedWorker      Worker?           @relation("ReplacementSuggested", fields: [suggestedWorkerId], references: [id])
  approvedWorker       Worker?           @relation("ReplacementApproved", fields: [approvedWorkerId], references: [id])
  volunteers           ReplacementVolunteer[]

  @@map("replacement_requests")
}

// A worker who volunteered to take over a replacement request.
model ReplacementVolunteer {
  id                   String   @id @default(cuid())
  replacementRequestId String
  workerId             String
  createdAt            DateTime @default(now())

  request              ReplacementRequest @relation(fields: [replacementRequestId], references: [id], onDelete: Cascade)
  worker               Worker             @relation(fields: [workerId], references: [id])

  @@unique([replacementRequestId, workerId])
  @@map("replacement_volunteers")
}

// A two-way swap: proposer's fromShift <-> target worker's toShift.
model ShiftSwap {
  id               String     @id @default(cuid())
  fromShiftId      String
  toShiftId        String
  fromWorkerId     String
  toWorkerId       String
  status           SwapStatus @default(PENDING_WORKER)
  note             String?
  workerRespondedAt DateTime?
  resolvedAt       DateTime?
  adminNote        String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  fromShift        Shift      @relation("SwapFromShift", fields: [fromShiftId], references: [id], onDelete: Cascade)
  toShift          Shift      @relation("SwapToShift", fields: [toShiftId], references: [id], onDelete: Cascade)
  fromWorker       Worker     @relation("SwapFromWorker", fields: [fromWorkerId], references: [id])
  toWorker         Worker     @relation("SwapToWorker", fields: [toWorkerId], references: [id])

  @@index([toWorkerId, status])
  @@index([fromWorkerId, status])
  @@map("shift_swaps")
}

// ─── Form Template ────────────────────────────────────────────────────────────

model FormTemplate {
  id          String          @id @default(cuid())
  name        String
  jobType     JobType
  isDefault   Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  questions   FormQuestion[]
  jobs        Job[]

  @@map("form_templates")
}

model FormQuestion {
  id             String                 @id @default(cuid())
  templateId     String
  questionText   String
  type           FormQuestionType
  visibility     FormQuestionVisibility @default(WORKER)
  isRequired     Boolean                @default(false)
  order          Int
  options        String[]               // For MULTIPLE_CHOICE / CHECKBOX
  createdAt      DateTime               @default(now())

  template       FormTemplate           @relation(fields: [templateId], references: [id])
  answers        FormAnswer[]

  @@map("form_questions")
}

// ─── Form Submission ──────────────────────────────────────────────────────────

model FormSubmission {
  id               String           @id @default(cuid())
  shiftId          String           @unique
  completionStatus CompletionStatus
  managerNote      String?
  submittedAt      DateTime         @default(now())
  editDeadline     DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  shift            Shift            @relation(fields: [shiftId], references: [id])
  answers          FormAnswer[]

  @@map("form_submissions")
}

model FormAnswer {
  id           String         @id @default(cuid())
  submissionId String
  questionId   String
  value        String         // JSON-serialized value
  createdAt    DateTime       @default(now())

  submission   FormSubmission @relation(fields: [submissionId], references: [id])
  question     FormQuestion   @relation(fields: [questionId], references: [id])

  @@map("form_answers")
}

// ─── Worker Report Approval ───────────────────────────────────────────────────

model WorkerReportApproval {
  id         String               @id @default(cuid())
  workerId   String
  month      Int
  year       Int
  status     ReportApprovalStatus @default(PENDING)
  note       String?
  resolvedAt DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  worker     Worker               @relation(fields: [workerId], references: [id])

  @@unique([workerId, month, year])
  @@map("worker_report_approvals")
}

// ─── Worker Monthly Report (versioned, publishable) ───────────────────────────

// Owner-published monthly worker report with immutable per-version snapshots
// (spec §24). Each publish creates a new version; approved/paid versions keep
// their snapshot. The "current" report for a month is the highest version.
enum WorkerReportStatus {
  DRAFT
  PUBLISHED
  CORRECTION_REQUESTED
  REVISED
  WORKER_APPROVED
  PAID
}

model WorkerMonthlyReport {
  id               String             @id @default(cuid())
  workerId         String
  month            Int
  year             Int
  version          Int
  status           WorkerReportStatus @default(PUBLISHED)
  snapshot         Json
  publishedById    String?
  publishedAt      DateTime           @default(now())
  workerApprovedAt DateTime?
  workerNote       String?
  paidAt           DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  worker           Worker             @relation(fields: [workerId], references: [id])

  @@unique([workerId, month, year, version])
  @@index([workerId, month, year])
  @@map("worker_monthly_reports")
}

// ─── Worker Report Note ───────────────────────────────────────────────────────

model WorkerReportNote {
  id         String         @id @default(cuid())
  workerId   String
  month      Int
  year       Int
  shiftId    String?
  type       ReportNoteType @default(COMMENT)
  message    String
  createdAt  DateTime       @default(now())

  worker     Worker         @relation(fields: [workerId], references: [id])

  @@index([workerId, month, year])
  @@map("worker_report_notes")
}

// ─── Job Expense ──────────────────────────────────────────────────────────────

model JobExpense {
  id          String          @id @default(cuid())
  jobId       String
  amount      Decimal         @db.Decimal(10, 2)
  description String
  category    ExpenseCategory
  notes       String?
  createdAt   DateTime        @default(now())

  job         Job             @relation(fields: [jobId], references: [id])

  @@map("job_expenses")
}

// ─── Business Expense (monthly overhead) ─────────────────────────────────────

model BusinessExpense {
  id          String          @id @default(cuid())
  date        DateTime
  amount      Decimal         @db.Decimal(10, 2)
  category    ExpenseCategory
  vendor      String?
  notes       String?
  receiptUrl  String?
  month       Int
  year        Int
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("business_expenses")
}

// ─── Month Close ──────────────────────────────────────────────────────────────

model MonthClose {
  id           String   @id @default(cuid())
  month        Int
  year         Int
  closedById   String
  closedAt     DateTime @default(now())
  reopenedById String?
  reopenedAt   DateTime?
  notes        String?

  @@unique([month, year])
  @@map("month_closes")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id           String      @id @default(cuid())
  performedById String
  action       AuditAction
  entityType   String
  entityId     String
  previousValue Json?
  newValue     Json?
  reason       String?
  createdAt    DateTime    @default(now())

  performedBy  User        @relation(fields: [performedById], references: [id])

  @@map("audit_logs")
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id         String   @id @default(cuid())
  userId     String
  title      String
  body       String
  data       Json?
  isRead     Boolean  @default(false)
  sentAt     DateTime @default(now())
  readAt     DateTime?

  @@map("notifications")
}

// ─── App Setting ──────────────────────────────────────────────────────────────

model AppSetting {
  key       String @id
  value     String
  notes     String?
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

