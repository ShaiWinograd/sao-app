// Workforce Scheduling & Billing — Prisma Schema
// Database: Azure Database for PostgreSQL Flexible Server

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  WORKER
}

enum AdminPermission {
  OPERATIONS
  FINANCE
}

enum CaseStatus {
  DRAFT
  ACTIVE
  READY_FOR_REVIEW
  COMPLETED
  CANCELLED
  // Full lifecycle states (spec: sale/planning → execution → payment/closure)
  LEAD
  QUOTATION_DRAFT
  AWAITING_APPROVAL
  RESERVED
  APPROVED_NO_DATES
  PARTIALLY_SCHEDULED
  READY_FOR_EXECUTION
  IN_PROGRESS
  AWAITING_COMPLETION
  AWAITING_BILLING
  AWAITING_PAYMENT
  PAID
}

enum QuotationStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
}

enum QuotationDatePrecision {
  EXACT
  PARTIAL
  EXPECTED_MONTH
  DATE_RANGE
  TO_BE_DETERMINED
}

enum QuotationSendChannel {
  WHATSAPP
  EMAIL
  MANUAL
}

enum QuotationApprovalMethod {
  DIGITAL
  SIGNED_DOCUMENT
  WHATSAPP
  EMAIL
  VERBAL
  MANUAL
}

enum JobType {
  PACKING
  UNPACKING
  HOME_ORGANIZATION
}

enum ServiceTimingPrecision {
  EXACT_DATE
  MULTIPLE_EXACT_DATES
  DATE_RANGE
  EXPECTED_MONTH
  EXPECTED_YEAR
  UNKNOWN
}

enum JobStatus {
  DRAFT
  PUBLISHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum StaffingMode {
  AUTO_APPROVE
  MANAGER_APPROVAL
}

enum WorkerSkill {
  SHIFT_LEADER
  PACKING_SPECIALIST
  UNPACKING_SPECIALIST
  ORGANIZATION_SPECIALIST
  DRIVER
  GENERAL_WORKER
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLISTED
  CANCELLED
}

enum AttendanceStatus {
  SCHEDULED
  CLOCKED_IN
  CLOCKED_OUT
  NO_SHOW
  CORRECTED
  AUTO_CLOCKED_OUT
}

enum AttendanceMethod {
  NORMAL
  ADMIN_CORRECTED
  MANUALLY_ADDED
  AUTO_CLOCK_OUT
}

enum ReplacementStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum InvoiceStatus {
  NOT_INVOICED
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum BillingModel {
  HOURLY
  FIXED
  CUSTOM
}

enum WorkerPaymentStatus {
  NOT_PREPARED
  READY_FOR_PAYMENT
  PARTIALLY_PAID
  PAID
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  BIT
  CHECK
  OTHER
}

enum AddressLabel {
  OLD_APARTMENT
  NEW_APARTMENT
  STORAGE
  OFFICE
  OTHER
}

enum FormQuestionType {
  YES_NO
  MULTIPLE_CHOICE
  CHECKBOX
  NUMBER
  SHORT_TEXT
  LONG_TEXT
  PHOTO_UPLOAD
  DATE
  SIGNATURE
}

enum FormQuestionVisibility {
  WORKER
  ADMIN
  OWNER
}

enum FormSubmissionStatus {
  NOT_SUBMITTED
  SUBMITTED
  WAIVED
}

enum CompletionStatus {
  COMPLETED
  PARTIALLY_COMPLETED
  NOT_COMPLETED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  CLOCK_IN
  CLOCK_OUT
  AUTO_CLOCK_OUT
  CORRECTION
  MONTH_CLOSE
  MONTH_REOPEN
  PERMISSION_CHANGE
}

enum ExpenseCategory {
  SOFTWARE
  MARKETING
  INSURANCE
  ACCOUNTANT
  OFFICE
  EQUIPMENT
  VEHICLE
  PARKING
  SUPPLIES
  OTHER
}

enum AdjustmentCategory {
  CUSTOMER_REFERRAL
  SHIFT_LEADER_BONUS
  SPECIAL_ASSIGNMENT_BONUS
  TRAVEL_REIMBURSEMENT
  EXTRA_RESPONSIBILITY
  CORRECTION
  DEDUCTION
}

enum ReportingBasis {
  ACCRUAL
  CASH
}

// ─── User (Clerk-managed identity, mirrored here for relations) ───────────────

model User {
  id          String   @id // Clerk user ID
  email       String   @unique
  firstName   String
  lastName    String
  role        UserRole
  isActive    Boolean  @default(true)
  permissions AdminPermission[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  workerProfile  Worker?
  auditLogs      AuditLog[]
  assignedCases  CustomerCase[]  @relation("CaseManager")

  @@map("users")
}

// ─── Worker ───────────────────────────────────────────────────────────────────

model Worker {
  id                  String   @id @default(cuid())
  userId              String   @unique
  firstName           String
  lastName            String
  phone               String
  email               String   @unique
  hourlyWage          Decimal  @db.Decimal(10, 2)
  dailyPaymentAmount  Decimal  @db.Decimal(10, 2)
  paymentMethod       PaymentMethod
  skills              WorkerSkill[]
  isActive            Boolean  @default(true)
  homeArea            String?
  notes               String?
  internalNotes       String?
  expoPushToken       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  user                User     @relation(fields: [userId], references: [id])
  shifts              Shift[]
  adjustments         WorkerAdjustment[]
  workerPayments      WorkerPayment[]
  availability        WorkerAvailability[]
  replacementRequests ReplacementRequest[] @relation("ReplacementOriginal")
  suggestedReplacements ReplacementRequest[] @relation("ReplacementSuggested")
  approvedReplacements ReplacementRequest[] @relation("ReplacementApproved")

  @@map("workers")
}

enum AvailabilityBlockType {
  DATE
  RANGE
  WEEKLY
}

// Dates/weekdays a worker has marked as unavailable (worker_web_spec §3).
model WorkerAvailability {
  id        String                @id @default(cuid())
  workerId  String
  type      AvailabilityBlockType
  startDate DateTime?
  endDate   DateTime?
  weekday   Int?
  reason    String?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  worker    Worker                @relation(fields: [workerId], references: [id])

  @@index([workerId])
  @@map("worker_availability")
}

// ─── Customer ─────────────────────────────────────────────────────────────────

model Customer {
  id                 String   @id @default(cuid())
  firstName          String
  lastName           String
  phone              String
  email              String
  preferredContact   String?
  notes              String?
  parkingInstructions String?
  accessInstructions String?
  elevatorInfo       String?
  petInfo            String?
  specialRequests    String?
  internalNotes      String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  addresses          Address[]
  cases              CustomerCase[]
  jobs               Job[]
  invoices           Invoice[]

  @@map("customers")
}

// ─── Address ──────────────────────────────────────────────────────────────────

model Address {
  id               String       @id @default(cuid())
  customerId       String
  fullAddress      String
  apartmentDetails String?
  label            AddressLabel
  accessNotes      String?
  parkingNotes     String?
  elevatorNotes    String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relations
  customer         Customer     @relation(fields: [customerId], references: [id])
  jobs             Job[]

  @@map("addresses")
}

// ─── Customer Case ────────────────────────────────────────────────────────────

model CustomerCase {
  id                   String     @id @default(cuid())
  customerId           String
  name                 String
  status               CaseStatus @default(ACTIVE)
  startDate            DateTime?
  latestActivityDate   DateTime?
  assignedAdminId      String?
  internalNotes        String?
  finalReportStatus    String?    // 'NOT_GENERATED' | 'DRAFT' | 'SENT'
  customerReportStatus String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  // Relations
  customer             Customer   @relation(fields: [customerId], references: [id])
  assignedAdmin        User?      @relation("CaseManager", fields: [assignedAdminId], references: [id])
  jobs                 Job[]
  invoices             Invoice[]
  quotations           Quotation[]
  plannedServices      PlannedServiceComponent[]

  @@map("customer_cases")
}

// ─── Job ──────────────────────────────────────────────────────────────────────

model Job {
  id                   String       @id @default(cuid())
  caseId               String
  customerId           String
  addressId            String
  jobType              JobType
  date                 DateTime
  plannedStart         DateTime
  plannedEnd           DateTime
  requiredWorkerCount  Int
  staffingMode         StaffingMode @default(AUTO_APPROVE)
  jobNotes             String?
  workerVisibleNotes   String?
  billingModel         BillingModel?
  billingRate          Decimal?     @db.Decimal(10, 2)
  locationRadiusMeters Int          @default(500)
  enableWaitlist       Boolean      @default(false)
  status               JobStatus    @default(DRAFT)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  // Relations
  case                 CustomerCase @relation(fields: [caseId], references: [id])
  customer             Customer     @relation(fields: [customerId], references: [id])
  address              Address      @relation(fields: [addressId], references: [id])
  slots                JobSlot[]
  shifts               Shift[]
  invoiceItems         InvoiceItem[]
  expenses             JobExpense[]
  formTemplate         FormTemplate? @relation(fields: [formTemplateId], references: [id])
  formTemplateId       String?

  @@map("jobs")
}

// ─── Job Slot (required role per position) ────────────────────────────────────

model JobSlot {
  id             String      @id @default(cuid())
  jobId          String
  requiredSkill  WorkerSkill?
  label          String?
  filledByShiftId String?

  job            Job         @relation(fields: [jobId], references: [id])

  @@map("job_slots")
}

// ─── Shift ────────────────────────────────────────────────────────────────────

model Shift {
  id                      String             @id @default(cuid())
  workerId                String
  jobId                   String
  slotId                  String?
  scheduledStart          DateTime
  scheduledEnd            DateTime
  actualStart             DateTime?
  actualEnd               DateTime?
  clockInLat              Float?
  clockInLon              Float?
  clockInDistanceMeters   Float?
  clockOutLat             Float?
  clockOutLon             Float?
  clockOutDistanceMeters  Float?
  attendanceStatus        AttendanceStatus   @default(SCHEDULED)
  clockInMethod           AttendanceMethod?
  clockOutMethod          AttendanceMethod?
  joinRequestStatus       JoinRequestStatus  @default(PENDING)
  replacementStatus       ReplacementStatus  @default(NONE)
  formStatus              FormSubmissionStatus @default(NOT_SUBMITTED)
  approvedHours           Decimal?           @db.Decimal(10, 2)
  hourlyWageSnapshot      Decimal            @db.Decimal(10, 2)
  dailyPaymentSnapshot    Decimal            @db.Decimal(10, 2)
  isDailyPaymentEligible  Boolean            @default(false)
  workerNameSnapshot      String
  requiresReview          Boolean            @default(false)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  // Relations
  worker                  Worker             @relation(fields: [workerId], references: [id])
  job                     Job                @relation(fields: [jobId], references: [id])
  attendanceCorrections   AttendanceCorrection[]
  locationChecks          LocationCheck[]
  replacementRequests     ReplacementRequest[]
  formSubmission          FormSubmission?

  @@map("shifts")
}

// ─── Attendance Correction ────────────────────────────────────────────────────

model AttendanceCorrection {
  id             String   @id @default(cuid())
  shiftId        String
  correctedById  String
  clockIn        DateTime?
  clockOut       DateTime?
  reason         String
  internalNote   String?
  createdAt      DateTime @default(now())

  shift          Shift    @relation(fields: [shiftId], references: [id])

  @@map("attendance_corrections")
}

// ─── Location Check ───────────────────────────────────────────────────────────

model LocationCheck {
  id              String   @id @default(cuid())
  shiftId         String
  latitude        Float
  longitude       Float
  distanceMeters  Float
  isWithinRadius  Boolean
  checkedAt       DateTime @default(now())
  workerResponse  String?  // 'END_SHIFT' | 'STILL_WORKING' | 'REPORT_ISSUE' | 'NO_RESPONSE'

  shift           Shift    @relation(fields: [shiftId], references: [id])

  @@map("location_checks")
}

// ─── Replacement Request ──────────────────────────────────────────────────────

model ReplacementRequest {
  id                   String            @id @default(cuid())
  shiftId              String
  requestedByWorkerId  String
  reason               String
  suggestedWorkerId    String?
  approvedWorkerId     String?
  status               ReplacementStatus @default(PENDING)
  adminNote            String?
  resolvedAt           DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  shift                Shift             @relation(fields: [shiftId], references: [id])
  requestedByWorker    Worker            @relation("ReplacementOriginal", fields: [requestedByWorkerId], references: [id])
  suggestedWorker      Worker?           @relation("ReplacementSuggested", fields: [suggestedWorkerId], references: [id])
  approvedWorker       Worker?           @relation("ReplacementApproved", fields: [approvedWorkerId], references: [id])

  @@map("replacement_requests")
}

// ─── Form Template ────────────────────────────────────────────────────────────

model FormTemplate {
  id          String          @id @default(cuid())
  name        String
  jobType     JobType
  isDefault   Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  questions   FormQuestion[]
  jobs        Job[]

  @@map("form_templates")
}

model FormQuestion {
  id             String                 @id @default(cuid())
  templateId     String
  questionText   String
  type           FormQuestionType
  visibility     FormQuestionVisibility @default(WORKER)
  isRequired     Boolean                @default(false)
  order          Int
  options        String[]               // For MULTIPLE_CHOICE / CHECKBOX
  createdAt      DateTime               @default(now())

  template       FormTemplate           @relation(fields: [templateId], references: [id])
  answers        FormAnswer[]

  @@map("form_questions")
}

// ─── Form Submission ──────────────────────────────────────────────────────────

model FormSubmission {
  id               String           @id @default(cuid())
  shiftId          String           @unique
  completionStatus CompletionStatus
  managerNote      String?
  submittedAt      DateTime         @default(now())
  editDeadline     DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  shift            Shift            @relation(fields: [shiftId], references: [id])
  answers          FormAnswer[]

  @@map("form_submissions")
}

model FormAnswer {
  id           String         @id @default(cuid())
  submissionId String
  questionId   String
  value        String         // JSON-serialized value
  createdAt    DateTime       @default(now())

  submission   FormSubmission @relation(fields: [submissionId], references: [id])
  question     FormQuestion   @relation(fields: [questionId], references: [id])

  @@map("form_answers")
}

// ─── Invoice ──────────────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(cuid())
  caseId         String
  customerId     String
  invoiceNumber  String        @unique
  status         InvoiceStatus @default(NOT_INVOICED)
  billableHours  Decimal?      @db.Decimal(10, 2)
  hourlyRate     Decimal?      @db.Decimal(10, 2)
  fixedPrice     Decimal?      @db.Decimal(10, 2)
  additionalFees Decimal       @default(0) @db.Decimal(10, 2)
  discount       Decimal       @default(0) @db.Decimal(10, 2)
  vatRate        Decimal       @default(0) @db.Decimal(5, 2)
  subtotal       Decimal       @db.Decimal(10, 2)
  vatAmount      Decimal       @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  dueDate        DateTime?
  sentAt         DateTime?
  notes          String?
  internalNotes  String?
  pdfUrl         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  case           CustomerCase  @relation(fields: [caseId], references: [id])
  customer       Customer      @relation(fields: [customerId], references: [id])
  items          InvoiceItem[]
  payments       CustomerPayment[]

  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  jobId       String?
  description String
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  invoice     Invoice @relation(fields: [invoiceId], references: [id])
  job         Job?    @relation(fields: [jobId], references: [id])

  @@map("invoice_items")
}

// ─── Customer Payment ─────────────────────────────────────────────────────────

model CustomerPayment {
  id            String        @id @default(cuid())
  invoiceId     String
  amount        Decimal       @db.Decimal(10, 2)
  paymentDate   DateTime
  method        PaymentMethod
  reference     String?
  notes         String?
  createdAt     DateTime      @default(now())

  invoice       Invoice       @relation(fields: [invoiceId], references: [id])

  @@map("customer_payments")
}

// ─── Worker Adjustment ────────────────────────────────────────────────────────

model WorkerAdjustment {
  id           String             @id @default(cuid())
  workerId     String
  amount       Decimal            @db.Decimal(10, 2)
  category     AdjustmentCategory
  reason       String
  shiftId      String?
  caseId       String?
  payrollMonth Int
  payrollYear  Int
  isIncluded   Boolean            @default(true)
  approvalStatus String           @default("PENDING") // 'PENDING' | 'APPROVED' | 'REJECTED'
  approvedById String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  worker       Worker             @relation(fields: [workerId], references: [id])

  @@map("worker_adjustments")
}

// ─── Worker Payment ───────────────────────────────────────────────────────────

model WorkerPayment {
  id          String             @id @default(cuid())
  workerId    String
  month       Int
  year        Int
  amount      Decimal            @db.Decimal(10, 2)
  paymentDate DateTime
  method      PaymentMethod
  reference   String?
  notes       String?
  createdAt   DateTime           @default(now())

  worker      Worker             @relation(fields: [workerId], references: [id])

  @@map("worker_payments")
}

// ─── Job Expense ──────────────────────────────────────────────────────────────

model JobExpense {
  id          String          @id @default(cuid())
  jobId       String
  amount      Decimal         @db.Decimal(10, 2)
  description String
  category    ExpenseCategory
  notes       String?
  createdAt   DateTime        @default(now())

  job         Job             @relation(fields: [jobId], references: [id])

  @@map("job_expenses")
}

// ─── Business Expense (monthly overhead) ─────────────────────────────────────

model BusinessExpense {
  id          String          @id @default(cuid())
  date        DateTime
  amount      Decimal         @db.Decimal(10, 2)
  category    ExpenseCategory
  vendor      String?
  notes       String?
  receiptUrl  String?
  month       Int
  year        Int
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("business_expenses")
}

// ─── Month Close ──────────────────────────────────────────────────────────────

model MonthClose {
  id           String   @id @default(cuid())
  month        Int
  year         Int
  closedById   String
  closedAt     DateTime @default(now())
  reopenedById String?
  reopenedAt   DateTime?
  notes        String?

  @@unique([month, year])
  @@map("month_closes")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id           String      @id @default(cuid())
  performedById String
  action       AuditAction
  entityType   String
  entityId     String
  previousValue Json?
  newValue     Json?
  reason       String?
  createdAt    DateTime    @default(now())

  performedBy  User        @relation(fields: [performedById], references: [id])

  @@map("audit_logs")
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id         String   @id @default(cuid())
  userId     String
  title      String
  body       String
  data       Json?
  isRead     Boolean  @default(false)
  sentAt     DateTime @default(now())
  readAt     DateTime?

  @@map("notifications")
}

// ─── App Setting ──────────────────────────────────────────────────────────────

model AppSetting {
  key       String @id
  value     String
  notes     String?
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

// ─── Quotation ───────────────────────────────────────────────────────────────

model Quotation {
  id        String          @id @default(cuid())
  caseId    String
  status    QuotationStatus @default(DRAFT)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  // Relations
  case      CustomerCase       @relation(fields: [caseId], references: [id])
  versions  QuotationVersion[]

  @@map("quotations")
}

// Immutable-after-approval snapshot of a quotation's scope, pricing, and timing.
model QuotationVersion {
  id                    String                   @id @default(cuid())
  quotationId           String
  versionNumber         Int
  status                QuotationStatus          @default(DRAFT)
  estimatedTotal        Decimal                  @db.Decimal(10, 2)
  datePrecision         QuotationDatePrecision   @default(TO_BE_DETERMINED)
  includedServices      String[]
  timingNote            String?
  validUntil            DateTime?
  notes                 String?
  details               Json?
  isAddendum            Boolean                  @default(false)
  replacesVersionId     String?
  createdById           String?
  sentAt                DateTime?
  approvedAt            DateTime?
  approvalMethod        QuotationApprovalMethod?
  approvalNotes         String?
  approvalAttachmentUrl String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  // Relations
  quotation             Quotation                @relation(fields: [quotationId], references: [id])
  sends                 QuotationSend[]

  @@unique([quotationId, versionNumber])
  @@map("quotation_versions")
}

// Audit record for each time a quotation version is sent to the customer.
model QuotationSend {
  id                    String               @id @default(cuid())
  versionId             String
  channel               QuotationSendChannel
  recipient             String
  versionNumberSnapshot Int
  sentById              String?
  createdAt             DateTime             @default(now())

  // Relations
  version               QuotationVersion     @relation(fields: [versionId], references: [id])

  @@map("quotation_sends")
}

// ─── Planned Service Component ───────────────────────────────────────────────

// The intended service for a project (independent of scheduled calendar jobs).
// Captures planned scope, timing precision, work estimate, and manager needs.
model PlannedServiceComponent {
  id                       String                 @id @default(cuid())
  caseId                   String
  serviceType              JobType
  timingPrecision          ServiceTimingPrecision @default(UNKNOWN)
  timingNote               String?
  estimatedWorkdays        Int?
  workersPerDay            Int?
  hoursPerDay              Decimal?               @db.Decimal(5, 2)
  requiresManager          Boolean                @default(false)
  reservedManagerPositions Int                    @default(0)
  notes                    String?
  sortOrder                Int                    @default(0)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  // Relations
  case                     CustomerCase           @relation(fields: [caseId], references: [id])

  @@map("planned_service_components")
}
