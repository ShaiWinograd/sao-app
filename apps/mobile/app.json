{
  "expo": {
    "name": "Space & Order",
    "slug": "space-order-workforce",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "workforce",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#25305C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.spaceorder.workforce",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "נדרש לאימות מיקום בזמן משמרת",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "נדרש לבדיקות מיקום תקופתיות במהלך משמרת פעילה"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#25305C"
      },
      "package": "com.spaceorder.workforce",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "FOREGROUND_SERVICE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "נדרש לבדיקות מיקום תקופתיות במהלך משמרת פעילה",
          "locationWhenInUsePermission": "נדרש לאימות מיקום בזמן משמרת"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#5E4A78"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
